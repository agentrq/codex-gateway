{
  "name": "@agentrq/codex-gateway",
  "version": "0.1.3",
  "description": "MCP bridge CLI for agentrq workspaces using OpenAI Codex",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "codex-gateway": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentrq/codex-gateway"
  },
  "keywords": [
    "codex",
    "openai",
    "mcp",
    "gateway",
    "bridge",
    "agentrq"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
